---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Layout from '~/layouts/PageLayout.astro';

// 直接导入图片
import wechatPay from '~/assets/images/wechat_pay.jpg';
import alipay from '~/assets/images/alipay1.jpg';

const metadata = {
  title: '请小郑喝杯咖啡',
};
---

<Layout metadata={metadata}>

  <div class="max-w-4xl mx-auto px-6 py-16 text-center">
    <h1 class="text-5xl font-bold mb-4 text-gray-900 dark:text-white">
      ☕ 请小郑喝杯咖啡
    </h1>
    <p class="text-xl text-gray-600 dark:text-gray-300 mb-12">
      感谢您对我的支持！<br>
      您的每一份支持都是我继续创作和分享的动力～
    </p>

    <div class="grid md:grid-cols-2 gap-12 max-w-2xl mx-auto">
      <!-- 微信赞赏 -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-xl">
        <div class="mb-6">
          <img src={wechatPay.src} 
               alt="微信赞赏二维码" 
               class="mx-auto rounded-xl shadow-md w-64 h-64 object-contain">
        </div>
        <h3 class="text-2xl font-semibold mb-2 text-green-600">微信赞赏</h3>
        <p class="text-gray-500 dark:text-gray-400">扫描二维码，请我喝杯咖啡</p>
      </div>

      <!-- 支付宝 -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-xl">
        <div class="mb-6">
          <img src={alipay.src} 
               alt="支付宝收款二维码" 
               class="mx-auto rounded-xl shadow-md w-64 h-64 object-contain">
        </div>
        <h3 class="text-2xl font-semibold mb-2 text-blue-600">支付宝</h3>
        <p class="text-gray-500 dark:text-gray-400">扫描二维码，支持一下</p>
      </div>
    </div>

    <!-- 加密货币 -->
    <div class="mt-12 text-sm text-gray-600 dark:text-gray-400">
      💰 加密货币 TRC20 (USDT)：
      <span class="font-mono bg-gray-100 dark:bg-gray-800 px-4 py-2 rounded break-all select-all font-bold text-gray-900 dark:text-white text-base">
        TXEn8yg6AxiRynigkEc1HGhKLZnAXJF4k5
      </span>
    </div>

    <div class="mt-16 text-sm text-gray-500">
      <p>金额不限，随喜即可～</p>
      <p class="mt-2">感谢每一位支持我的朋友！</p>
    </div>

    <a href="/" 
       class="mt-12 inline-block px-8 py-4 bg-gray-900 text-white rounded-full hover:bg-gray-800 transition">
      ← 返回首页
    </a>
  </div>

</Layout>